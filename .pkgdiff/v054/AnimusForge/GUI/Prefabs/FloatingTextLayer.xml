<Prefab>
  <Window>
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" DoNotAcceptEvents="true" ClipContents="false">
      <Children>
        <ListPanel DataSource="{Items}" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" DoNotAcceptEvents="true" ClipContents="false">
          <ItemTemplate>
            <Widget DoNotAcceptEvents="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="0" SuggestedHeight="0" HorizontalAlignment="Left" VerticalAlignment="Top" PositionXOffset="@X" PositionYOffset="@Y" ClipContents="false">
              <Children>
                <Widget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" AlphaFactor="@Alpha" ClipContents="false">
                  <Children>
                    <Widget WidthSizePolicy="Fixed" SuggestedWidth="@BubbleWidth" HeightSizePolicy="CoverChildren" Sprite="BlankWhiteSquare_9" Color="#00000000" ClipContents="false">
                      <Children>
                        <TextWidget
                          Text="@Text"
                          WidthSizePolicy="StretchToParent"
                          HeightSizePolicy="CoverChildren"
                          MarginLeft="12"
                          MarginRight="12"
                          MarginTop="6"
                          MarginBottom="6"
                          Brush.FontSize="@FontSize"
                          Brush.TextHorizontalAlignment="Left"
                          Brush.TextVerticalAlignment="Center"
                          ClipContents="false" />
                      </Children>
                    </Widget>
                  </Children>
                </Widget>
              </Children>
            </Widget>
          </ItemTemplate>
        </ListPanel>
      </Children>
    </Widget>
  </Window>
</Prefab>
