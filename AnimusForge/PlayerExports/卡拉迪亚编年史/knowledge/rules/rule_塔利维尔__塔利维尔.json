  "RagShortTexts": [
    "塔利维尔橄榄油味道温和，瓦兰迪亚贵族喜爱。"
  ],
  "SemanticPrototypes": [],
  "Variants": [
    {
      "Priority": 0,
      "When": null,
      "Content": "塔利维尔是塔利维尔堡附近的一座村庄，坐落在瓦兰迪亚腹地的特朗河谷中段。这里的村民们利用谷地温暖的气候，在山坡上种植橄榄，橄榄油是他们的主要产出。"
    },
    {
      "Priority": 0,
      "When": {
        "HeroIds": null,
