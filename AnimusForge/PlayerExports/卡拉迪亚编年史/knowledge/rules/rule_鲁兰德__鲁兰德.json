    "鲁兰德"
  ],
  "RagShortTexts": [
    "鲁兰德村庄位于特朗林谷，靠近帕拉汶德，以橡子喂猪。"
  ],
  "SemanticPrototypes": [],
  "Variants": [
    {
      "Priority": 0,
      "When": null,
      "Content": "鲁兰德是帕拉汶德附近的一座村庄，位于特朗中部的林谷中。村民们以橡树林地的橡子为饲料来饲养猪，猪肉和熏肉供给帕拉汶德的市场。"
    },
    {
      "Priority": 0,
      "When": {
        "HeroIds": null,
