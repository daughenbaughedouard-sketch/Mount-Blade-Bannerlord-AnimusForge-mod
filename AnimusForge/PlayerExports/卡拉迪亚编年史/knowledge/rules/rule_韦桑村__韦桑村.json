  "RagShortTexts": [
    "韦桑村位于沙拉斯附近，埃皮尔山溪水滋养橄榄树。"
  ],
  "SemanticPrototypes": [],
  "Variants": [
    {
      "Priority": 0,
      "When": null,
      "Content": "韦桑村是沙拉斯附近的一座村庄，位于从埃皮尔山丘流下来的小溪旁。这片温暖的土地很适合橄榄树的生长，山坡上到处都是橄榄园。沙拉斯港的商船常把这里的橄榄油运往海外。"
    },
    {
      "Priority": 0,
