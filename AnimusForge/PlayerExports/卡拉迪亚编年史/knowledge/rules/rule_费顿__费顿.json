  "RagShortTexts": [
    "费顿橄榄园在特朗河畔，近比斯坎丘陵山口。"
  ],
  "SemanticPrototypes": [],
  "Variants": [
    {
      "Priority": 0,
      "When": null,
      "Content": "费顿是翁加尔堡附近的一座村庄，位于蜿蜒曲折的特朗河的一个拐角处，离通往比斯坎丘陵的山口不远。村民们在温暖、干燥的一侧山坡上种植橄榄，橄榄油是他们的主要产出。"
    },
